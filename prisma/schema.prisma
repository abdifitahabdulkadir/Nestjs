

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

enum ROLE {
  admin
  manager
  interns
  engineer
}

model Employee {
  id Int @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name String 
  email String @unique
  role ROLE
}