{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "prisma/generated/**/*",
        "outDir": "dist/prisma/generated"
      }
    ],
    "watchAssets": true,
    "deleteOutDir": true
  }
}
